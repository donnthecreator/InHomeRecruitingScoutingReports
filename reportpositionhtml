async function sendPDF(){
  if(document.activeElement && document.activeElement.blur) document.activeElement.blur();
  await new Promise(r=>setTimeout(r, 100));
  
  buildPrintView();
  const prospect = gv('fProspect') || 'prospect';
  const fname = `InHome_${state.position}_${prospect.replace(/[^a-zA-Z0-9]/g,'_')}.pdf`;
  const btn = document.getElementById('pdfBtn');
  const el = document.getElementById('printView');
  const overlay = document.getElementById('buildOverlay');
  
  btn.disabled = true;
  btn.textContent = 'Generating...';
  
  try{
    if(typeof html2pdf === 'undefined') throw new Error('PDF library not loaded');

    overlay.classList.add('show');
    // Make element visible for capture
    el.style.display = 'block';
    el.style.position = 'static';
    el.style.width = '794px';
    
    // Critical: wait for fonts and full layout
    if(document.fonts && document.fonts.ready){ await document.fonts.ready; }
    el.getBoundingClientRect();
    await new Promise(r=>setTimeout(r, 400));

    const opt = {
      filename: fname,
      image: {type:'jpeg', quality:0.95},
      html2canvas: {scale:2},
      jsPDF: {unit:'mm', format:'a4', orientation:'portrait'}
    };
    
    const blob = await html2pdf().set(opt).from(el).outputPdf('blob');
    
    el.style.display = 'none';
    overlay.classList.remove('show');

    if(!blob || blob.size < 8000) throw new Error('PDF generation failed');

    const file = new File([blob], fname, {type:'application/pdf'});

    // Try native share first (iOS/Android)
    if(navigator.canShare && navigator.canShare({files:[file]})){
      await navigator.share({
        files:[file],
        title:'InHome Scouting Report',
        text:`${prospect} (${state.position})`
      });
      showToast('Shared ✓');
    } else {
      // Fallback: download
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = fname;
      a.click();
      URL.revokeObjectURL(url);
      showToast('PDF downloaded ✓');
    }
  } catch(err){
    el.style.display = 'none';
    overlay.classList.remove('show');
    console.error('PDF error:', err);
    showToast('Error generating PDF');
  }
  
  btn.disabled = false;
  btn.textContent = 'Save & Send PDF';
}

