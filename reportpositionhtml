function gv(id){ return document.getElementById(id).value.trim(); }
function gradeWord(n){ return n ? `${n} — ${GRADE_LABELS[n-1]}` : "Not graded"; }

const IMPRESSION_LABELS = ["Red Flag","Guarded","Solid","Impressive","Elite Makeup"];

function buildInterviewPV(){
  const answered = INTERVIEW_QS.filter(q=>state.interview[q.id]);
  const hasAny = answered.length || state.learnStyle || state.interviewGrade;
  if(!hasAny) return '';

  let inner = '';
  if(state.learnStyle || state.interviewGrade){
    inner += `<div class="pv-grid" style="margin-bottom:10px;">
      ${state.learnStyle ? `<div class="pv-item"><span class="k">Learns best by</span><span class="v">${state.learnStyle}</span></div>` : ''}
      ${state.interviewGrade ? `<div class="pv-item"><span class="k">Interview Impression</span><span class="v">${state.interviewGrade} — ${IMPRESSION_LABELS[state.interviewGrade-1]}</span></div>` : ''}
    </div>`;
  }
  inner += answered.map(q=>`
    <div style="margin-top:9px;">
      <div style="font-size:11.5px; font-weight:700; color:#555C78;">${q.q}</div>
      <div class="pv-narrative" style="margin-top:2px;">${state.interview[q.id].replace(/</g,'&lt;')}</div>
    </div>`).join('');

  return `<div class="pv-sec"><h3>Player Interview</h3>${inner}</div>`;
}

