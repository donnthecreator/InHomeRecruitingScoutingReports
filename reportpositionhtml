<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>InHome | EIS Scouting Report</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@500;600;700&family=Barlow:wght@400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<style>
  :root{
    --navy:#060D2E;
    --navy2:#0A1440;
    --blue:#1A3AFF;
    --blue-dim:#1A3AFF33;
    --paper:#F5F6FA;
    --line:#E3E6F0;
    --ink:#0B0F1E;
    --mute:#6B7290;
    --good:#1FA35C;
    --warn:#E0A419;
    --bad:#D93B3B;
    --card:#FFFFFF;
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  body{margin:0; background:var(--paper); color:var(--ink); font-family:'Barlow',sans-serif; padding-bottom:120px;}
  h1,h2,h3,.disp{font-family:'Barlow Condensed',sans-serif; font-weight:700; letter-spacing:.01em;}
  .topbar{background:var(--navy); color:#fff; padding:18px 18px 22px;}
  .topbar-row{display:flex; align-items:center; justify-content:space-between;}
  .logo{display:flex; align-items:center; gap:8px;}
  .logo svg{width:26px; height:26px;}
  .logo-text{font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:19px; letter-spacing:.03em;}
  .logo-text b{color:var(--blue);}
  .badge{background:var(--blue); color:#fff; font-family:'Barlow Condensed',sans-serif; font-weight:600; font-size:12px; letter-spacing:.08em; text-transform:uppercase; padding:5px 10px; border-radius:20px;}
  .eis-tag{color:#8C9AE0; font-size:11px; letter-spacing:.14em; text-transform:uppercase; margin-top:10px; font-weight:600;}
  .pos-title{font-size:34px; line-height:1; margin-top:4px;}
  .pos-select-wrap{margin-top:14px;}
  select.pos-select{width:100%; background:var(--navy2); color:#fff; border:1px solid #29346B; border-radius:10px; padding:11px 12px; font-family:'Barlow',sans-serif; font-size:15px; font-weight:600;}

  .wrap{max-width:640px; margin:0 auto; padding:0 14px;}
  .section{background:var(--card); border:1px solid var(--line); border-radius:14px; margin-top:14px; overflow:hidden;}
  .section-head{display:flex; align-items:center; justify-content:space-between; padding:15px 16px; cursor:pointer; user-select:none;}
  .section-head-left{display:flex; align-items:center; gap:10px;}
  .step-num{width:24px; height:24px; border-radius:7px; background:var(--navy); color:#fff; font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:13px; display:flex; align-items:center; justify-content:center; flex-shrink:0;}
  .section-head h2{margin:0; font-size:18px;}
  .section-sub{font-size:12px; color:var(--mute); margin-top:1px; font-weight:500;}
  .chev{transition:transform .2s; color:var(--mute);}
  .section.open .chev{transform:rotate(180deg);}
  .section-body{max-height:0; overflow:hidden; transition:max-height .25s ease;}
  .section.open .section-body{max-height:4000px;}
  .section-body-inner{padding:2px 16px 18px;}

  label.field-label{display:block; font-size:12px; font-weight:600; color:var(--mute); text-transform:uppercase; letter-spacing:.06em; margin:12px 0 6px;}
  input[type=text], input[type=number], textarea{width:100%; border:1.5px solid var(--line); border-radius:9px; padding:11px 12px; font-family:'Barlow',sans-serif; font-size:15px; background:#fff; color:var(--ink);}
  textarea{min-height:100px; resize:vertical;}
  .grid2{display:grid; grid-template-columns:1fr 1fr; gap:10px;}

  .arche-row{display:flex; gap:8px; flex-wrap:wrap; margin-top:8px;}
  .arche-btn{flex:1; min-width:90px; border:1.5px solid var(--line); background:#fff; border-radius:10px; padding:10px 8px; text-align:center; cursor:pointer;}
  .arche-btn b{display:block; font-family:'Barlow Condensed',sans-serif; font-size:16px; font-weight:700;}
  .arche-btn span{font-size:10.5px; color:var(--mute); font-weight:500;}
  .arche-btn.sel{border-color:var(--blue); background:var(--blue-dim);}
  .arche-btn.sel b{color:var(--blue);}
  .arche-desc{font-size:12.5px; color:var(--mute); margin-top:8px; line-height:1.45; background:var(--paper); border-radius:8px; padding:9px 10px; display:none;}
  .arche-desc.show{display:block;}

  .trait-card{border:1.5px solid var(--line); border-radius:11px; padding:12px; margin-top:10px;}
  .trait-card .t-name{font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:16px;}
  .trait-card .t-prompt{font-size:12.5px; color:var(--mute); margin-top:2px; line-height:1.4;}
  .grade-row{display:flex; gap:6px; margin-top:10px;}
  .grade-btn{flex:1; border:1.5px solid var(--line); background:#fff; border-radius:8px; padding:9px 0; text-align:center; cursor:pointer; font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:15px; color:var(--mute);}
  .grade-btn small{display:block; font-family:'Barlow',sans-serif; font-weight:600; font-size:8.5px; letter-spacing:.03em; text-transform:uppercase; margin-top:2px;}
  .grade-btn.g1.sel{background:var(--bad); border-color:var(--bad); color:#fff;}
  .grade-btn.g2.sel{background:#E88A3B; border-color:#E88A3B; color:#fff;}
  .grade-btn.g3.sel{background:var(--warn); border-color:var(--warn); color:#fff;}
  .grade-btn.g4.sel{background:#6FBF6F; border-color:#6FBF6F; color:#fff;}
  .grade-btn.g5.sel{background:var(--good); border-color:var(--good); color:#fff;}
  .raw-metric{margin-top:9px;}
  .raw-metric input{max-width:140px; display:inline-block;}
  .raw-metric-label{font-size:11.5px; color:var(--mute); font-weight:600; margin-right:8px;}

  .gate-row{display:flex; align-items:center; justify-content:space-between; border:1.5px solid var(--line); border-radius:10px; padding:10px 12px; margin-top:9px;}
  .gate-label{font-size:14px; font-weight:600; max-width:56%; line-height:1.3;}
  .gate-btns{display:flex; gap:5px;}
  .gate-btn{border:1.5px solid var(--line); background:#fff; border-radius:7px; padding:7px 10px; font-size:11.5px; font-weight:700; font-family:'Barlow Condensed',sans-serif; letter-spacing:.03em; text-transform:uppercase; cursor:pointer; color:var(--mute);}
  .gate-btn.pass.sel{background:var(--good); border-color:var(--good); color:#fff;}
  .gate-btn.concern.sel{background:var(--warn); border-color:var(--warn); color:#fff;}
  .gate-btn.fail.sel{background:var(--bad); border-color:var(--bad); color:#fff;}

  .iq-wrap{padding:6px 4px 2px;}
  .iq-value{font-family:'Barlow Condensed',sans-serif; font-size:44px; font-weight:700; color:var(--blue); text-align:center;}
  .iq-value span{font-size:18px; color:var(--mute); font-weight:600;}
  input[type=range]{width:100%; accent-color:var(--blue); margin-top:4px;}
  .iq-scale{display:flex; justify-content:space-between; font-size:10.5px; color:var(--mute); font-weight:600;}
  .iq-note{font-size:11.5px; color:var(--mute); text-align:center; margin-top:8px; line-height:1.4;}

  .score-card{background:var(--navy); border-radius:14px; margin-top:14px; padding:18px; color:#fff;}
  .score-top{display:flex; justify-content:space-between; align-items:flex-end;}
  .score-top .lbl{font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:#8C9AE0; font-weight:600;}
  .score-big{font-family:'Barlow Condensed',sans-serif; font-size:56px; font-weight:700; line-height:1;}
  .score-bars{margin-top:14px;}
  .sb-row{display:flex; align-items:center; gap:10px; margin-top:8px;}
  .sb-label{width:82px; font-size:11.5px; font-weight:600; color:#B8C0EE;}
  .sb-track{flex:1; height:7px; background:#1B255C; border-radius:5px; overflow:hidden;}
  .sb-fill{height:100%; background:var(--blue); border-radius:5px;}
  .sb-val{width:34px; text-align:right; font-size:12px; font-weight:700; font-family:'Barlow Condensed',sans-serif;}
  .ti-row{display:flex; justify-content:space-between; margin-top:14px; padding-top:12px; border-top:1px solid #1B255C; font-size:12px; color:#8C9AE0;}
  .ti-row b{color:#fff; font-family:'Barlow Condensed',sans-serif; font-size:14px;}

  .tier-row{display:flex; flex-direction:column; gap:8px; margin-top:8px;}
  .tier-btn{border:1.5px solid var(--line); background:#fff; border-radius:10px; padding:11px 12px; text-align:left; cursor:pointer;}
  .tier-btn b{display:block; font-family:'Barlow Condensed',sans-serif; font-size:15px; font-weight:700;}
  .tier-btn span{font-size:11.5px; color:var(--mute);}
  .tier-btn.sel{border-color:var(--blue); background:var(--blue-dim);}

  .footer-bar{position:fixed; bottom:0; left:0; right:0; background:#fff; border-top:1px solid var(--line); padding:12px 14px; display:flex; gap:10px; align-items:center; z-index:50;}
  .footer-bar .fb-status{flex:1; font-size:12px; color:var(--mute); font-weight:600;}
  .submit-btn{background:var(--blue); color:#fff; border:none; border-radius:10px; padding:13px 22px; font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:15.5px; letter-spacing:.02em; cursor:pointer;}
  .submit-btn:disabled{opacity:.5;}
  .toast{position:fixed; top:14px; left:50%; transform:translateX(-50%); background:var(--navy); color:#fff; padding:11px 18px; border-radius:9px; font-size:13.5px; font-weight:600; z-index:100; opacity:0; transition:opacity .25s; pointer-events:none;}
  .toast.show{opacity:1;}

  .pdf-btn{background:#fff; color:var(--navy); border:1.5px solid var(--navy); border-radius:10px; padding:12px 16px; font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:15.5px; letter-spacing:.02em; cursor:pointer;}
  .pdf-btn:disabled{opacity:.5;}

  /* ---------- PRINT / PDF VIEW ---------- */
  /* ---------- PRINT / PDF VIEW ---------- */
  /* Initially hidden, shown during PDF capture, then hidden again. */
  #printView{width:794px; background:#fff; color:#0B0F1E; font-family:'Barlow',sans-serif; margin:0 auto; display:none;}
  .pv-page{padding:22px 42px 28px;}
  .pv-head{background:var(--navy); color:#fff; padding:22px 42px 18px; display:flex; justify-content:space-between; align-items:flex-start;}
  .pv-logo{font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:24px; letter-spacing:.03em;}
  .pv-logo b{color:var(--blue);}
  .pv-head-tag{font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:#8C9AE0; font-weight:600; margin-top:3px;}
  .pv-score-chip{text-align:right;}
  .pv-score-chip .n{font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:42px; line-height:1;}
  .pv-score-chip .l{font-size:10px; letter-spacing:.12em; text-transform:uppercase; color:#8C9AE0; font-weight:600;}
  .pv-name{font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:30px; line-height:1.05;}
  .pv-meta{font-size:12.5px; color:#555C78; margin-top:4px; font-weight:500;}
  .pv-sec{margin-top:15px;}
  .pv-sec h3{font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:14px; letter-spacing:.08em; text-transform:uppercase; color:var(--navy); border-bottom:2px solid var(--blue); padding-bottom:4px; margin:0 0 8px;}
  .pv-grid{display:grid; grid-template-columns:1fr 1fr; gap:6px 24px;}
  .pv-item{display:flex; justify-content:space-between; font-size:13px; padding:5px 0; border-bottom:1px solid #EEF0F6;}
  .pv-item .k{color:#555C78; font-weight:500;}
  .pv-item .v{font-weight:700; font-family:'Barlow Condensed',sans-serif; font-size:14px;}
  .pv-item .v.pass{color:var(--good);} .pv-item .v.concern{color:var(--warn);} .pv-item .v.fail{color:var(--bad);}
  .pv-scores{display:flex; gap:10px; margin-top:4px;}
  .pv-score-box{flex:1; border:1.5px solid #E3E6F0; border-radius:9px; padding:10px 12px; text-align:center;}
  .pv-score-box .n{font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:22px;}
  .pv-score-box .l{font-size:9.5px; letter-spacing:.06em; text-transform:uppercase; color:#555C78; font-weight:600; margin-top:2px;}
  .pv-narrative{font-size:13px; line-height:1.55; white-space:pre-wrap; color:#20263F;}
  .pv-tier{display:inline-block; background:var(--blue-dim); color:var(--blue); border:1.5px solid var(--blue); border-radius:8px; padding:7px 14px; font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:15px;}
  .pv-foot{margin-top:16px; padding-top:10px; border-top:1px solid #E3E6F0; font-size:10.5px; color:#8A90A8; display:flex; justify-content:space-between;}

  @media print{
    body > *:not(#printView){display:none !important;}
    #printView{display:block !important; width:auto;}
    body{padding:0; background:#fff;}
  }

  #buildOverlay{position:fixed; inset:0; background:var(--navy); z-index:9999; display:none; align-items:center; justify-content:center; flex-direction:column; gap:14px;}
  #buildOverlay.show{display:flex;}
  #buildOverlay .msg{color:#fff; font-family:'Barlow Condensed',sans-serif; font-weight:700; font-size:20px; letter-spacing:.04em;}
  .spinner{width:34px; height:34px; border:3.5px solid #29346B; border-top-color:var(--blue); border-radius:50%; animation:spin .8s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg);}}
</style>
</head>
<body>

<div class="toast" id="toast"></div>

<div class="topbar">
  <div class="topbar-row">
    <div class="logo">
      <svg viewBox="0 0 24 24" fill="none"><path d="M3 12L12 4L21 12" stroke="#1A3AFF" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/><path d="M6 11.5V20H18V11.5" stroke="white" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <div class="logo-text">IN<b>HOME</b></div>
    </div>
    <div class="badge">Scout Report</div>
  </div>
  <div class="eis-tag">EIS ALL-22 &middot; Position Evaluation</div>
  <div class="pos-title" id="posTitle">Quarterback</div>
  <div class="pos-select-wrap">
    <select class="pos-select" id="posSelect"></select>
  </div>
</div>

<div class="wrap">

  <!-- 1. Prospect & Scout Info -->
  <div class="section open" data-sec="1">
    <div class="section-head" onclick="toggleSec(this)">
      <div class="section-head-left"><div class="step-num">1</div><div><h2>Prospect &amp; Scout</h2><div class="section-sub">Who's being evaluated, who's grading</div></div></div>
      <svg class="chev" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="#6B7290" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div class="section-body"><div class="section-body-inner">
      <label class="field-label">Prospect Name</label>
      <input type="text" id="fProspect" placeholder="First Last">
      <div class="grid2">
        <div><label class="field-label">Class / Grad Yr</label><input type="text" id="fClass" placeholder="2027"></div>
        <div><label class="field-label">High School</label><input type="text" id="fSchool" placeholder="School name"></div>
      </div>
      <div class="grid2">
        <div><label class="field-label">Height</label><input type="text" id="fHeight" placeholder="6'1&quot;"></div>
        <div><label class="field-label">Weight</label><input type="text" id="fWeight" placeholder="185 lbs"></div>
      </div>
      <label class="field-label">Film Link (Hudl/YouTube)</label>
      <input type="text" id="fFilm" placeholder="https://">
      <label class="field-label">Evaluation Camp / Location</label>
      <input type="text" id="fCamp" placeholder="e.g. U of West Alabama Camp">
      <div class="grid2">
        <div><label class="field-label">Scout Name</label><input type="text" id="fScout" placeholder="Your name"></div>
        <div><label class="field-label">Date Evaluated</label><input type="text" id="fDate" placeholder="MM/DD/YYYY"></div>
      </div>
    </div></div>
  </div>

  <!-- 2. Archetype -->
  <div class="section" data-sec="2">
    <div class="section-head" onclick="toggleSec(this)">
      <div class="section-head-left"><div class="step-num">2</div><div><h2>Role / Archetype</h2><div class="section-sub" id="archSub">Tag how this player projects</div></div></div>
      <svg class="chev" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="#6B7290" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div class="section-body"><div class="section-body-inner">
      <div class="arche-row" id="archeRow"></div>
      <div class="arche-desc" id="archeDesc"></div>
    </div></div>
  </div>

  <!-- 3. Film Grading -->
  <div class="section" data-sec="3">
    <div class="section-head" onclick="toggleSec(this)">
      <div class="section-head-left"><div class="step-num">3</div><div><h2>Film Grade (EIS)</h2><div class="section-sub">Poor &rarr; Elite, per trait</div></div></div>
      <svg class="chev" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="#6B7290" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div class="section-body"><div class="section-body-inner" id="filmTraits"></div></div>
  </div>

  <!-- 4. Athletic Testing -->
  <div class="section" data-sec="4">
    <div class="section-head" onclick="toggleSec(this)">
      <div class="section-head-left"><div class="step-num">4</div><div><h2>Athletic Testing</h2><div class="section-sub">Grade the trait, log the number if you have it</div></div></div>
      <svg class="chev" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="#6B7290" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div class="section-body"><div class="section-body-inner" id="athleticTraits"></div></div>
  </div>

  <!-- 5. Production -->
  <div class="section" data-sec="5">
    <div class="section-head" onclick="toggleSec(this)">
      <div class="section-head-left"><div class="step-num">5</div><div><h2>Production</h2><div class="section-sub">On-field output vs. level of competition</div></div></div>
      <svg class="chev" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="#6B7290" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div class="section-body"><div class="section-body-inner" id="productionTraits"></div></div>
  </div>

  <!-- 6. Gates -->
  <div class="section" data-sec="6">
    <div class="section-head" onclick="toggleSec(this)">
      <div class="section-head-left"><div class="step-num">6</div><div><h2>The Gates</h2><div class="section-sub">Character &amp; competitive traits — gate, don't score</div></div></div>
      <svg class="chev" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="#6B7290" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div class="section-body"><div class="section-body-inner" id="gatesList"></div></div>
  </div>

  <!-- 7. Football IQ -->
  <div class="section" data-sec="7">
    <div class="section-head" onclick="toggleSec(this)">
      <div class="section-head-left"><div class="step-num">7</div><div><h2>Football IQ</h2><div class="section-sub">Standalone gauge — not part of composite score</div></div></div>
      <svg class="chev" width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="#6B7290" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div class="section-body"><div class="section-body-inner">
      <div class="iq-wrap">
        <div class="iq-value" id="iqVal">5<span>/10</span></div>
        <input type="range" min="1" max="10" value="5" id="iqSlider" oninput="onIQ(this.value)">
        <div class="iq-scale"><span>Reactive / late</span><span>Instinctive / anticipatory</span></div>
        <div class="iq-note" id="iqNote">Processing speed, recognition, and adjustment relative to the assignment.</div>
      </div>
    </div></div>
  </div>

  <!-- 8. InHome Score -->
  <div class="score-card">
    <div class="score-top">
      <div><div class="lbl">InHome Score</div><div class="score-big" id="scoreBig">0.0</div></div>
      <div style="text-align:right"><div class="lbl">Football IQ</div><div class="score-big" id="iqBig" style="font-size:32px;">5.0</div></div>
    </div>
    <div class="score-bars">
      <div class="sb-row"><div class="sb-label">Film 50%</div><div class="sb-track"><div class="sb-fill" id="barFilm" style="width:0%"></div></div><div class="sb-val" id="valFilm">0</div></div>
      <div class="sb-row"><div class="sb-label">Athletic 25%</div><div class="sb-track"><div class="sb-fill" id="barAth" style="width:0%"></div></div><div class="sb-val" id="valAth">0</div></div>
      <div class="sb-row"><div class="sb-label">Character 15%</div><div class="sb-track"><div class="sb-fill" id="barChar" style="width:0%"></div></div><div class="sb-val" id="valChar">0</div></div>
      <div class="sb-row"><div class="sb-label">Production 10%</div><div class="sb-track"><div class="sb-fill" id="barProd" style="width:0%"></div></div><div class="sb-val" id="valProd">0</div></div>
    </div>
    <div class="ti-row"><span>Translation Index (IQ &times; Film &divide; Athletic)</span><b id="tiVal">&mdash;</b></div>
  </div>

  <!-- 9. Narrative -->
  <div class="section" data-sec="9">
    <div class="section-head" onclick="toggleSec(this)">
      <div class="section-head-left"><div class="step-num">8</div><div><h2>Scout's Notes</h2><div class="section-sub">Narrative — what the numbers don't say</div></div></div>
