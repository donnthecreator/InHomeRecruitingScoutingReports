function showToast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2600);
}

async function submitReport(){
  const cfg = POSITIONS[state.position];
  const payload = {
    prospect: document.getElementById('fProspect').value,
    position: state.position,
    positionLabel: cfg.label,
    archetype: state.archetype,
    classYear: document.getElementById('fClass').value,
    school: document.getElementById('fSchool').value,
    height: document.getElementById('fHeight').value,
    weight: document.getElementById('fWeight').value,
    filmLink: document.getElementById('fFilm').value,
    scoutName: document.getElementById('fScout').value,
    evalCamp: document.getElementById('fCamp').value,
    dateEvaluated: document.getElementById('fDate').value,
    footballIQ: state.iq,
    narrative: document.getElementById('fNarrative').value,
    recommendationTier: state.tier,
    inhomeScore: document.getElementById('scoreBig').textContent,
    translationIndex: document.getElementById('tiVal').textContent,
    raw: {
      traitGrades: state.film,
      athleticGrades: state.athletic,
      athleticRaw: state.athleticRaw,
      productionGrades: state.production,
      productionRaw: state.productionRaw,
      gates: state.gates,
      interview: {
        learnStyle: state.learnStyle,
        impression: state.interviewGrade,
        answers: state.interview
      }
    }
  };

  document.getElementById('submitBtn').disabled = true;
  document.getElementById('submitBtn').textContent = 'Submitting...';

  try{
    const res = await fetch('/.netlify/functions/submit-report', {
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify(payload)
    });
    if(res.ok){
      showToast('Report submitted ✓');
      document.getElementById('submitBtn').textContent = 'Submitted';
    } else {
      throw new Error('Server error');
    }
  } catch(err){
    showToast('Could not submit — check connection');
    document.getElementById('submitBtn').textContent = 'Submit Report';
    document.getElementById('submitBtn').disabled = false;
  }
}

/* ---------------- PDF EXPORT ---------------- */
