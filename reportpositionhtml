/* ---------------- INIT ---------------- */
function getPositionFromURL(){
  const p = new URLSearchParams(window.location.search).get('position');
  return (p && POSITIONS[p.toUpperCase()]) ? p.toUpperCase() : 'QB';
}

function initPosSelect(){
  const sel = document.getElementById('posSelect');
  sel.innerHTML = Object.keys(POSITIONS).map(k=>`<option value="${k}">${POSITIONS[k].label}</option>`).join('');
  sel.value = state.position;
  sel.onchange = ()=> loadPosition(sel.value);
}

function loadPosition(posKey){
  state.position = posKey;
  state.archetype = null;
  state.film = {}; state.athletic = {}; state.production = {};
  state.athleticRaw = {}; state.productionRaw = {};
  state.gates = {};
  state.learnStyle = null; state.interview = {}; state.interviewGrade = null;
  document.querySelectorAll('#learnRow .arche-btn').forEach(b=>b.classList.remove('sel'));
  document.querySelectorAll('#row-interview-impression .grade-btn').forEach(b=>b.classList.remove('sel'));
  renderInterview();
  const cfg = POSITIONS[posKey];
  document.getElementById('posTitle').textContent = cfg.label;
  document.getElementById('posSelect').value = posKey;
  document.getElementById('archSub').textContent = `Tag how this ${cfg.label.toLowerCase()} projects`;

  // Archetypes
  const archeRow = document.getElementById('archeRow');
  archeRow.innerHTML = cfg.archetypes.map(a=>`<div class="arche-btn" data-k="${a.k}" onclick="pickArche('${a.k}')"><b>${a.k}</b><span>role</span></div>`).join('');
  document.getElementById('archeDesc').classList.remove('show');

  // Film traits
  document.getElementById('filmTraits').innerHTML = cfg.film.map(t=>traitCardHTML(t,'film')).join('');

  // Athletic
  document.getElementById('athleticTraits').innerHTML = cfg.athletic.map(t=>traitCardHTML(t,'athletic',true)).join('');

  // Production
  document.getElementById('productionTraits').innerHTML = cfg.production.map(t=>traitCardHTML(t,'production',true)).join('');

  // Gates
  document.getElementById('gatesList').innerHTML = cfg.gates.map(g=>gateHTML(g)).join('');

  computeScores();
}

function traitCardHTML(t, group, withMetric){
  let metricHTML = '';
  if(withMetric){
    metricHTML = `<div class="raw-metric"><span class="raw-metric-label">${t.metric}</span><input type="text" oninput="setRaw('${group}','${t.id}',this.value)" placeholder="optional"></div>`;
  }
  return `
  <div class="trait-card">
    <div class="t-name">${t.name}</div>
    <div class="t-prompt">${t.p || ''}</div>
    <div class="grade-row" id="row-${group}-${t.id}">
      ${[1,2,3,4,5].map(g=>`<div class="grade-btn g${g}" onclick="setGrade('${group}','${t.id}',${g})">${g}<small>${GRADE_LABELS[g-1]}</small></div>`).join('')}
    </div>
    ${metricHTML}
  </div>`;
}

function gateHTML(label){
  const id = label.replace(/[^a-zA-Z0-9]/g,'');
  return `
  <div class="gate-row">
    <div class="gate-label">${label}</div>
    <div class="gate-btns" id="gate-${id}">
      <div class="gate-btn pass" onclick="setGate('${id}','pass')">Pass</div>
      <div class="gate-btn concern" onclick="setGate('${id}','concern')">Concern</div>
      <div class="gate-btn fail" onclick="setGate('${id}','fail')">Fail</div>
    </div>
  </div>`;
}

/* ---------------- INTERACTIONS ---------------- */
function toggleSec(headEl){
  headEl.closest('.section').classList.toggle('open');
}

function pickArche(k){
  state.archetype = k;
  document.querySelectorAll('.arche-btn').forEach(b=>b.classList.toggle('sel', b.dataset.k===k));
  const cfg = POSITIONS[state.position];
  const a = cfg.archetypes.find(x=>x.k===k);
  const desc = document.getElementById('archeDesc');
  desc.textContent = a.d;
  desc.classList.add('show');
}

function setGrade(group, id, val){
  state[group][id] = val;
  const row = document.getElementById(`row-${group}-${id}`);
  row.querySelectorAll('.grade-btn').forEach((b,i)=>b.classList.toggle('sel', i+1===val));
  computeScores();
}

function setRaw(group, id, val){
  const store = group==='athletic' ? state.athleticRaw : state.productionRaw;
  store[id] = val;
}

function setGate(id, val){
  state.gates[id] = val;
  const wrap = document.getElementById(`gate-${id}`);
  wrap.querySelectorAll('.gate-btn').forEach(b=>b.classList.toggle('sel', b.classList.contains(val)));
  computeScores();
}

function onIQ(v){
  state.iq = parseInt(v);
  document.getElementById('iqVal').innerHTML = `${v}<span>/10</span>`;
  document.getElementById('iqBig').textContent = parseFloat(v).toFixed(1);
  computeScores();
}

/* ---------------- INTERVIEW ---------------- */
function renderInterview(){
  let html = '';
  let lastCat = '';
  INTERVIEW_QS.forEach(item=>{
    if(item.cat !== lastCat){
      html += `<label class="field-label" style="margin-top:16px;">${item.cat}</label>`;
      lastCat = item.cat;
    }
    html += `
    <div class="trait-card">
      <div class="t-prompt" style="font-size:13.5px; color:#20263F; font-weight:600;">"${item.q}"</div>
      <textarea style="min-height:64px; margin-top:8px; font-size:14px;" placeholder="His answer / your read..." oninput="setInterview('${item.id}', this.value)"></textarea>
    </div>`;
  });
  document.getElementById('interviewQs').innerHTML = html;
}

function setInterview(id, val){
  if(val.trim()) state.interview[id] = val.trim();
  else delete state.interview[id];
}

function pickLearn(k){
  state.learnStyle = k;
  document.querySelectorAll('#learnRow .arche-btn').forEach(b=>b.classList.toggle('sel', b.dataset.l===k));
}

function setIntGrade(val){
  state.interviewGrade = val;
  const row = document.getElementById('row-interview-impression');
  row.querySelectorAll('.grade-btn').forEach((b,i)=>b.classList.toggle('sel', i+1===val));
}

document.getElementById('tierRow').addEventListener('click', (e)=>{
  const btn = e.target.closest('.tier-btn');
  if(!btn) return;
  state.tier = btn.dataset.tier;
  document.querySelectorAll('.tier-btn').forEach(b=>b.classList.toggle('sel', b===btn));
});

/* ---------------- SCORING ---------------- */
function avg(obj){
  const vals = Object.values(obj);
  if(!vals.length) return null;
  return vals.reduce((a,b)=>a+b,0)/vals.length;
}

function computeScores(){
  const filmAvg = avg(state.film);
  const athAvg = avg(state.athletic);
  const prodAvg = avg(state.production);

  const gateVals = Object.values(state.gates);
  let charScore = null;
  if(gateVals.length){
    const pts = gateVals.map(g=> g==='pass'?100 : g==='concern'?60 : 0);
    charScore = pts.reduce((a,b)=>a+b,0)/pts.length;
  }

  const filmScore = filmAvg!==null ? filmAvg*20 : 0;
  const athScore = athAvg!==null ? athAvg*20 : 0;
  const prodScore = prodAvg!==null ? prodAvg*20 : 0;
  const cScore = charScore!==null ? charScore : 0;

  const composite = (filmScore*0.50) + (athScore*0.25) + (cScore*0.15) + (prodScore*0.10);

  document.getElementById('scoreBig').textContent = composite.toFixed(1);
  document.getElementById('barFilm').style.width = filmScore+'%';
  document.getElementById('barAth').style.width = athScore+'%';
  document.getElementById('barChar').style.width = cScore+'%';
  document.getElementById('barProd').style.width = prodScore+'%';
  document.getElementById('valFilm').textContent = filmScore.toFixed(0);
  document.getElementById('valAth').textContent = athScore.toFixed(0);
  document.getElementById('valChar').textContent = cScore.toFixed(0);
  document.getElementById('valProd').textContent = prodScore.toFixed(0);

  let ti = '—';
  if(filmAvg!==null && athAvg!==null && athScore>0){
    ti = ((state.iq * filmScore) / athScore).toFixed(2);
  }
  document.getElementById('tiVal').textContent = ti;

  updateStatus();
}

function updateStatus(){
  const cfg = POSITIONS[state.position];
  const filmDone = Object.keys(state.film).length === cfg.film.length;
  const gatesDone = Object.keys(state.gates).length === cfg.gates.length;
  const ready = state.archetype && filmDone && gatesDone && document.getElementById('fProspect').value.trim();
  document.getElementById('submitBtn').disabled = !ready;
  document.getElementById('fbStatus').textContent = ready ? 'Ready to submit' : 'Fill out prospect info, archetype, film grades & gates';
}
document.getElementById('fProspect').addEventListener('input', updateStatus);

